# .env — copy to your repo root and fill in your keys
# Never commit this file (it's in .gitignore)

# ── LLM API keys ──────────────────────────────────────────────────────────
MISTRAL_API_KEY=
DEEPSEEK_API_KEY=
GROQ_API_KEY=
GEMINI_API_KEY=
ADMIN_SECRET=
# ── Ollama (if running on host or another container) ──────────────────────
# If Ollama runs on the Docker host:
OLLAMA_HOST=http://host.docker.internal:11434
# If Ollama runs in a sibling container (adjust service name):
# OLLAMA_HOST=http://ollama:11434

# ── Server ────────────────────────────────────────────────────────────────
HOST_PORT=5000           # port exposed on the Linux server
UVICORN_RELOAD=0         # set to 1 in dev (use the dev profile instead)
